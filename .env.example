# Multilogin Configuration
MULTILOGIN_API_KEY=your_multilogin_api_key_here
MULTILOGIN_PORT=45001

# Script Configuration
THREADS=2
PROFILE_ROTATION_DELAY=5  # Seconds to wait after closing one profile before opening the next
MAX_URLS_PER_PROFILE=0  # Force-rotate after N successful downloads (0 = no cap)

# Proxy Source: 'file' loads from proxies.txt, 'multilogin' generates per profile
PROXY_SOURCE=file

# Multilogin Proxy Generation (only used when PROXY_SOURCE=multilogin)
MULTILOGIN_PROXY_COUNTRY=us
MULTILOGIN_PROXY_REGION=          # Optional, e.g. new_jersey
MULTILOGIN_PROXY_CITY=            # Optional, e.g. east_brunswick
MULTILOGIN_PROXY_PROTOCOL=http    # http | https | socks4 | socks5
MULTILOGIN_PROXY_SESSION_TYPE=sticky
MULTILOGIN_PROXY_IPTTL=0
